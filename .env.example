# ── Banco de dados (Railway MySQL fornece essa URL automaticamente) ──────────
DATABASE_URL="mysql://user:pass@host:3306/pokehub"

# ── Sessão (obrigatório em produção — string longa e aleatória) ──────────────
JWT_SECRET="troque-por-uma-string-aleatoria-bem-longa"

# ── URL pública do app (usada nos callbacks do Google OAuth) ─────────────────
APP_URL="https://seu-app.up.railway.app"

# ── Admin: quem se registrar com este email vira admin automaticamente ───────
OWNER_EMAIL="owner@example.com"
SUPPORT_EMAIL="support@example.com"

# ── Google OAuth (opcional — sem isso, só login por email/senha) ─────────────
# Crie em https://console.cloud.google.com/apis/credentials
# Redirect URI autorizado: {APP_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Artigos diários com IA (opcional — sem chave, o endpoint só aceita
#    artigos pré-escritos enviados pelo cron) ─────────────────────────────────
OPENAI_API_KEY=""

# ── Segredo do cron de artigos (header x-cron-secret) ────────────────────────
CRON_SECRET="outra-string-aleatoria"

# ── Preços CardMarket via RapidAPI (opcional) ────────────────────────────────
RAPIDAPI_KEY=""

# ── Catálogo real de produtos selados e preços em USD (Scrydex) ─────────────
SCRYDEX_API_KEY=""
SCRYDEX_TEAM_ID=""

# ── Pasta de uploads (no Railway, monte um Volume neste caminho) ─────────────
DATA_DIR="./data"
